{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/shared/**/*",
    "tailwind.config.ts",
    "vite.config.ts",
    "vite.config.tauri.ts",
    "vitest.config.ts",
    "vitest.setup.ts"
  ]
}
