# Default: detect text and normalize to LF on commit, LF in working tree
* text=auto eol=lf

# ──────────────────────────────────────────────────────────────
# Source code (always LF)
# ──────────────────────────────────────────────────────────────
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.rs        text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.svg       text eol=lf
*.xml       text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf

# Dotfiles & config
.gitignore       text eol=lf
.gitattributes   text eol=lf
.editorconfig    text eol=lf
.prettierrc      text eol=lf
.prettierrc.*    text eol=lf
.eslintrc.*      text eol=lf
.npmrc           text eol=lf
.nvmrc           text eol=lf

# ──────────────────────────────────────────────────────────────
# Windows-only scripts (always CRLF, in case any are added later)
# ──────────────────────────────────────────────────────────────
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# ──────────────────────────────────────────────────────────────
# Lock files (LF, never auto-merged)
# ──────────────────────────────────────────────────────────────
package-lock.json   text eol=lf -diff
bun.lock            text eol=lf -diff
Cargo.lock          text eol=lf -diff
yarn.lock           text eol=lf -diff
pnpm-lock.yaml      text eol=lf -diff

# ──────────────────────────────────────────────────────────────
# Binary assets (never touched)
# ──────────────────────────────────────────────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.icns      binary
*.bmp       binary
*.tiff      binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.7z        binary
*.exe       binary
*.dll       binary
*.so        binary
*.dylib     binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.eot       binary
*.mp3       binary
*.mp4       binary
*.webm      binary
*.wav       binary
*.heapsnapshot binary
