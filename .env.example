# Copy to .env and set your Efferd Pro registry token
EFFERD_REGISTRY_TOKEN='registry.YOUR_TOKEN_HERE'

# Cloudflare Pages Functions secret for /testimonial/list CMS access.
# Set this in landing/.env for local wrangler pages dev, and as a
# Cloudflare Pages production secret for deployed moderation.
TESTIMONIALS_ADMIN_TOKEN='replace-with-a-long-random-token'

