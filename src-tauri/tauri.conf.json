{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Termul Manager",
  "version": "0.2.3",
  "identifier": "com.termul-manager.app",
  "build": {
    "beforeDevCommand": "npx vite --config vite.config.tauri.ts",
    "devUrl": "http://localhost:5173/tauri-index.html",
    "beforeBuildCommand": "npx vite build --config vite.config.tauri.ts",
    "frontendDist": "../dist-tauri"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "tauri-index.html",
        "title": "Termul Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "visible": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost; worker-src 'self' blob:; img-src 'self' asset: http://asset.localhost data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
